# AutoDWG Cross-Checker 환경변수 예시
# 복사 후 .env 로 이름 바꿔서 사용하세요.

# 추출 엔진: ezdxf (기본) 또는 vision (준비 중)
EXTRACTOR=ezdxf

# ODA File Converter 실행 파일 경로
# Windows 예: C:\Program Files\ODA\ODAFileConverter\ODAFileConverter.exe
# Linux 예:   /usr/bin/ODAFileConverter
ODA_EXEC_PATH=

# 로그 레벨: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 아래 경로는 Docker 볼륨 마운트 시 자동 설정됨 (보통 변경 불필요)
# CONFIG_DIR=backend/data/configs
# UPLOAD_DIR=backend/data/uploads
# RESULT_DIR=backend/data/results
# LOG_FILE=logs/autodwg.log
